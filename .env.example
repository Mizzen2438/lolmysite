# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL unset to use a local SQLite file (quick start).
# For PostgreSQL (Docker Compose / production), e.g.:
# DATABASE_URL=postgres://lolmysite:lolmysite@localhost:5432/lolmysite
DATABASE_URL=

# Account policy (F-UNIQ-07)
MIN_DISCORD_ACCOUNT_AGE_DAYS=90
