# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave DATABASE_URL unset to use a local SQLite file (quick start).
# Docker Compose (local Postgres): postgres://neonq:neonq@localhost:5432/neonq
# Production = Supabase。アプリは session プーラー(5432)推奨。マイグレーションは
# 直接接続(5432)に対して実行する(transaction プーラー 6543 は避ける):
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Account policy (F-UNIQ-07)
MIN_DISCORD_ACCOUNT_AGE_DAYS=90

# Discord OAuth (https://discord.com/developers/applications)
# Add redirect URL: http://127.0.0.1:8000/accounts/discord/login/callback/
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Static files: enable hashed/manifest storage in production (after collectstatic)
DJANGO_MANIFEST_STATIC=False

# Cache (Riot API responses + refresh cooldown). Empty = in-memory.
# Production = Upstash Redis(TLS の rediss:// URL):
# CACHE_URL=rediss://default:<password>@<region>.upstash.io:6379
CACHE_URL=

# Riot API (https://developer.riotgames.com/)
RIOT_API_KEY=
RIOT_PLATFORM=jp1
RIOT_REGIONAL=asia
RIOT_CACHE_TTL=86400
RIOT_REFRESH_COOLDOWN=600
# Production API Key 申請時の所有権確認コード(/riot.txt で配信)
RIOT_VERIFICATION_CODE=

# Production
# Comma-separated hostnames and full-origin CSRF list (apex + www + Render host):
# DJANGO_ALLOWED_HOSTS=neonq.online,www.neonq.online,neonq.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://neonq.online,https://www.neonq.online
# True にすると apex(neonq.online)を www.neonq.online へ 301 リダイレクト:
# DJANGO_PREPEND_WWW=False
# Error monitoring (N-12)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
